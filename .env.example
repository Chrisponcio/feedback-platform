# ============================================================
# Pulse — Environment Variables
# ============================================================
# Copy this file to .env.local in apps/web and fill in the values.
# Never commit .env.local to version control.
# ============================================================

# ---- Supabase (required) ------------------------------------
# Found in Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER-SIDE ONLY. Never expose to the browser.
# Found in Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret — used to verify tokens in edge middleware
# Found in Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret

# ---- App URLs -----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Vercel Cron Security -----------------------------------
# A secret used to authenticate Vercel Cron requests to /api/cron/*
# Generate with: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ---- Email (Resend) — Phase 1 --------------------------------
# https://resend.com
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Pulse Surveys

# ---- SMS (Twilio) — Phase 2 ----------------------------------
# https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ---- Encryption — PII fields --------------------------------
# 32-byte hex key for AES-256 encryption of respondent_email/phone
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ---- Stripe — Billing (Phase 3) ----------------------------
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ---- Slack Integration (Phase 3) ----------------------------
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-slack-signing-secret

# ---- OpenAI — AI Sentiment (Phase 4) -----------------------
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ---- Mapbox — Geolocation (Phase 4) ------------------------
# https://account.mapbox.com
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-public-token

# ---- Vercel KV — Dashboard Cache (Phase 5) -----------------
# Auto-populated by Vercel when you connect a KV store
KV_URL=your-kv-url
KV_REST_API_URL=your-kv-rest-api-url
KV_REST_API_TOKEN=your-kv-rest-api-token
KV_REST_API_READ_ONLY_TOKEN=your-kv-rest-api-read-only-token
