{
  "buildCommand": "pnpm turbo build --filter=@pulse/web...",
  "outputDirectory": "apps/web/.next",
  "installCommand": "pnpm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/report-snapshots",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/cleanup-invitations",
      "schedule": "0 0 * * *"
    }
  ]
}
